# Growth Agent Environment Variables
# Copy to .env and fill in values
# Used by: OpenTofu (via TF_VAR_*), local debugging

# Umami Cloud API
UMAMI_API_KEY=your-umami-api-key
UMAMI_WEBSITE_ID=e41ae7d9-a536-426d-b40e-f2488b11bf95

# IONOS AI Model Hub
IONOS_API_TOKEN=your-ionos-api-token

# Scaleway S3
SCW_ACCESS_KEY=your-scw-access-key
SCW_SECRET_KEY=your-scw-secret-key
S3_BUCKET=my-imagestore
S3_STATE_PREFIX=growth-agent/

# Social Media
MASTODON_ACCESS_TOKEN=
MASTODON_INSTANCE=https://mastodon.social
BLUESKY_APP_PASSWORD=
BLUESKY_HANDLE=fretchen.eu

# --- OpenTofu Variables (export as TF_VAR_*) ---
# export TF_VAR_ionos_api_token="$IONOS_API_TOKEN"
# export TF_VAR_mastodon_access_token="$MASTODON_ACCESS_TOKEN"
# export TF_VAR_bluesky_app_password="$BLUESKY_APP_PASSWORD"
# export TF_VAR_umami_api_key="$UMAMI_API_KEY"
# export TF_VAR_scw_access_key="$SCW_ACCESS_KEY"
# export TF_VAR_scw_secret_key="$SCW_SECRET_KEY"
