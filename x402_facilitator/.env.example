# Scaleway Configuration (required for deployment)
SCW_ACCESS_KEY=SCWXXXXXXXXXXXXXXXXX
SCW_SECRET_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SCW_DEFAULT_ORGANIZATION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SCW_DEFAULT_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Facilitator Configuration
# IMPORTANT: Set these as Scaleway Secrets, not in .env for production!
FACILITATOR_WALLET_PRIVATE_KEY=0x...
FACILITATOR_WALLET_PUBLIC_KEY=0x...

# Optional: Custom RPC endpoints (see getRpcUrl in chain_utils.ts). Unset falls back to
# each chain's public endpoint. Set these for production to use a dedicated RPC provider
# (Infura, Alchemy, Ankr, etc.) — the public endpoints are aggressively rate-limited.
# RPC_URL_EIP155_10=https://opt-mainnet.g.alchemy.com/v2/YOUR_API_KEY
# RPC_URL_EIP155_8453=https://base-mainnet.g.alchemy.com/v2/YOUR_API_KEY
# RPC_URL_EIP155_84532=https://base-sepolia.g.alchemy.com/v2/YOUR_API_KEY
# RPC_URL_EIP155_11155420=https://opt-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Local development
NODE_ENV=test
LOG_LEVEL=info

# Fee Configuration
# Per-transaction fee in USDC smallest unit (6 decimals)
# Default: 10000 (0.01 USDC). Set to 0 to disable fees.
FACILITATOR_FEE_AMOUNT=10000

# Weekly wallet report (walletreportcron) — emails balances + 7-day USDC activity.
# Sending is skipped (with a warning) unless all three of SCW_SECRET_KEY, TEM_PROJECT_ID
# and NOTIFICATION_EMAIL are set. SCW_SECRET_KEY (above) doubles as the TEM auth token.
# The report is sent from comments@fretchen.eu (already a verified TEM sender).
# TEM_PROJECT_ID: Scaleway Transactional Email project id
# NOTIFICATION_EMAIL: inbox that receives the report
# LOW_GAS_THRESHOLD_ETH: warn when the wallet's native ETH balance drops below this
# TEM_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# NOTIFICATION_EMAIL=you@example.com
# LOW_GAS_THRESHOLD_ETH=0.005

# Notebooks only (notebooks/*.ipynb read this same .env — see notebooks/README.md)
# TEST_WALLET_PRIVATE_KEY: payer/buyer key, must hold testnet USDC + gas on the target network
# NFT_WALLET_PUBLIC_KEY: recipient address used by the demo notebooks
# TEST_WALLET_PRIVATE_KEY=0x...
# NFT_WALLET_PUBLIC_KEY=0x...

# batch-settlement recipient whitelist
# Gates which payTo/receiver addresses may use the fee-free batch-settlement scheme
# (see x402_whitelist.ts) — NOT the payer. Comma-separated addresses.
# BATCH_SETTLEMENT_MANUAL_WHITELIST: honored on every network (use once ready for mainnet)
# BATCH_SETTLEMENT_TEST_WALLETS: honored on testnets only (Optimism Sepolia, Base Sepolia)
# BATCH_SETTLEMENT_MANUAL_WHITELIST=0x...
# BATCH_SETTLEMENT_TEST_WALLETS=0x...
